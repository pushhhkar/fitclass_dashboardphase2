# ============================================================================
#  FitClass CRM — Phase 2 Auth Foundation — environment template
#  Copy this file to `.env.local` and fill in real values. NEVER commit
#  `.env.local` (it is gitignored). This `.example` file is safe to commit.
# ============================================================================

# ── PUBLIC (browser-exposed) ────────────────────────────────────────────────
# Any var prefixed with NEXT_PUBLIC_ is inlined into the client bundle at build
# time and is therefore VISIBLE to anyone. Only put non-secret, low-trust
# values here. The Supabase URL + anon key are designed to be public; access is
# constrained by Row Level Security (RLS) policies on the database side.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── SERVER-ONLY (never exposed to the browser) ──────────────────────────────
# These MUST NOT be prefixed with NEXT_PUBLIC_. They are read only in server
# code (route handlers, server components, middleware-adjacent server logic).
#
# SUPABASE_SERVICE_ROLE_KEY bypasses ALL Row Level Security — it is full
# admin access to the database. Leaking it = full data breach. It is used only
# by the server-side `supabaseAdmin` client. Rotate immediately if exposed.
#
# JWT_SECRET signs and verifies session tokens. Anyone who has it can mint
# valid sessions for ANY user/role. Use a long, high-entropy random string
# (e.g. `openssl rand -base64 48`). Use a DIFFERENT secret per environment.

SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=

# ── SEED (CLI only — `npm run db:seed-admin`) ───────────────────────────────
# Used once to create the first admin user. The seed is idempotent (re-running
# with an existing email does nothing). The plaintext password is hashed with
# bcrypt before storage and is never logged. Rotate/remove after first use.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=FitClass Admin
